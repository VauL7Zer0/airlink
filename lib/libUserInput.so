		userInput = poll_input
        if userInput and not userInput == "F1" then
            showHelp = false
        end if
		if userInput == "F1" then
			if showHelp == false then
				showHelp = true
			else if showHelp == true then
				showHelp = false
			end if
		end if        
		if userInput == "F2" then
			if showThemeList == false then
				showThemeList = true
			else if showThemeList == true then
				showThemeList = false
			end if
		end if
        if userInput == "F9" then
			if hopConnections == false then
				hopConnections = true
			else if hopConnections == true then
				hopConnections = false
			end if            
        end if
		if userInput == "Home" then
			myShell.launch("/usr/bin/Browser.exe", myRouter.public_ip + ":80")
		end if
		if userInput == "End" then
			myShell.launch("/usr/bin/Browser.exe", myRouter.local_ip + ":8080")
		end if		
		if userInput == "Insert" then
            if showThemeList == true then                    
                myShell.launch("/usr/bin/Notepad.exe", home_dir + "/Airlink/Theme/" + themeList[themeIndexSelection].name)
            else
			    myShell.launch("/usr/bin/Notepad.exe", wifiInfo_fileLocation)
            end if
		end if
		if userInput == "Tab" then
			interfaceSelection = interfaceSelection + 1
			if interfaceSelection > network_device_list.len - 1 then interfaceSelection = 0
		end if
		if userInput == "UpArrow" then
            if showThemeList == true then
                themeIndexSelection = themeIndexSelection - 1
                if themeIndexSelection < -2 then themeIndexSelection = -2
            else
                wifiIndex = wifiIndex - 1
                if wifiIndex < 0 then wifiIndex = 0
            end if
		end if
		if userInput == "DownArrow" then
            if showThemeList == true then
                themeIndexSelection = themeIndexSelection + 1
                themeCount = (myComputer.File(home_dir + "/Airlink/Theme").get_files).len
                if themeIndexSelection > (themeCount - 1) then themeIndexSelection = (themeCount - 1)
            else
                wifiIndex = wifiIndex + 1
                if wifiIndex > getBroadcasts.len - 1 then wifiIndex = (getBroadcasts.len - 1)
            end if
		end if

        if userInput == "F3" then
            sortedBroadcasts = []
            for broadcast in getBroadcasts
                parts = broadcast.split(" ")
                signalStrength = to_int(parts[1].remove("%"))
                sortedBroadcasts.push({"bssid": parts[0], "signalStrength": signalStrength, "essid": parts[2]})
            end for
            sortedBroadcasts.sort("signalStrength")
            sortedBroadcasts.reverse
			autoCrackLog = ["Cracking All WiFi Broadcasts. CTRL+C to Interrupt.".color("LimeGreen").bold.underline.color("LightGreen")]
            for signal in sortedBroadcasts
                hasEntry = false
                if shadowContent.len > 0 then
                    for wifi in shadowList
                        shadowPart = wifi.split(" ")
						if shadowPart.hasIndex(2) then
							if shadowPart[2].trim == signal.essid.trim then
								hasEntry = true
								break
							end if
						end if
                    end for
                end if
                // Crack if not in database
                if not hasEntry then
					clear_screen
					reqAcks = get_acks(signal.signalStrength)
					if autoCrackLog.len > 0 then
						for autolog in autoCrackLog
							print(autolog, true)
						end for
					end if
                    print("◆ Monitoring: ".color(themeData.signalColor5) + (signal.essid).color(themeData.ipAddressColor) + " (" + signal.signalStrength + "%)" + " Getting ACKs: " + str(reqAcks).color(themeData.ackInfoColor), true)
                    Crypto.aireplay(signal.bssid, signal.essid, reqAcks)
                    crackedPassword = Crypto.aircrack(current_path + "/file.cap")                    
                    if typeof(crackedPassword) == "string" then
						autoCrackLog.push(("◆ Cracked ".bold.color(themeData.passColor) + (signal.essid).color(themeData.ipAddressColor) + " Password: " + crackedPassword).underline)
                        capFile = myComputer.File(current_path + "/file.cap")
                        if capFile then capFile.delete
                        
                        newEntry = signal.bssid + " " + signal.signalStrength + "% " + signal.essid + " " + crackedPassword + " whitelist " + myComputer.public_ip
                        if shadowContent then
                            shadowContent = shadowContent + char(10) + newEntry
                        else
                            shadowContent = newEntry
                        end if
                        
                        shadowFile.set_content(shadowContent)
                        shadowList = (shadowContent.split(char(10))).crop
                        lastPassword = crackedPassword
                        lastNetwork = signal.essid
                    end if
                end if
            end for
        end if		
