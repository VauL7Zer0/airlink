    // Look for a file
    // @description **Description:**
    // @description Check to see if the specified file exists
    // @description ---
    //
    // @description **Parameters:**
    // @param {string} filePath
    // @description - `filePath`:`<string>`
    // @param {string} `fileName`:`<string>`
    // @description - `fileName`:`<string>`
    //
    // @description **Parameter Defaults:**
    // @description - `none`
    //
    // @description **Return:**
    // @return {boolean}
    // @description `boolean`:`true`|`false`
    // @description ---
    //    
    // @description **Author:** Svarii
    // @description **Version:** 0.0.1
    // @description ---
    //
    // @description ***footnotes***   
    // @description Parameters are not checked for validity   
    // @description ---        
    //
    // @example
    // file_exists("/DatabaseDir", "addressData.db") // return true if found, otherwise false
    // @description ---  		
        file_exists = function(filePath, fileName)
            locals.hostComputer = get_shell.host_computer
            locals.fileLocation = locals.filePath + "/" + locals.fileName
            locals.fileObj = locals.hostComputer.File(locals.fileLocation)
            if not locals.fileObj then
                return false
            else
                return true
            end if		
        end function

// Generate currentStatus Object
	// @description **Description:**
	// Generate an object that contains basic environment information
	// @description ---
	//
	// @description **Parameters:**
	// @description - none 
	// @description ---
	//
	// @description **Return:**
	// @return {map<string,maps>} - System Object {.shell and .computer}
	// @description `computerStatus`:`<maps><string>` currentStatus Object
	// @description - `.compInfo` - computerInformation Object
	// @description - - `.name`
	// @description - - `.home`
	// @description - - `.location`
	// @description - - `.path`	
	// @description - - `.user`	
	// @description - - `.has_internet`
	// @description - `.ipInfo` - ipInformation Object
	// @description - - `.local`
	// @description - - `.public`
	// @description - - `.gateway`	
	// @description ---   
	//    
	//  @example iScan = new id_self
	//  @example print typeof(iScan)  //Output: currentStatus
	//  @example 
	//  @example	print iScan.compInfo.name  //Output: The name of the computer
	//  @example	print iScan.compInfo.has_internet  //Output: boolean 1 or 0
	//  @example	print iScan.ipInfo.public  //Output: public ip of computer
id_self = function()
	locals.localComputer = get_shell.host_computer
        if not typeof(locals.localComputer) == "computer" then return "Failed to fetch local computer object."
        if locals.localComputer.is_network_active then
	        locals.localRouter = get_router
            if not typeof(locals.localRouter) == "router" then return "Failed to fetch local router object."		
        end if
    locals.ipInformation = {"classID": "ipInformation", "local": locals.localComputer.local_ip, "public": locals.localComputer.public_ip, "gateway":locals.localComputer.network_gateway}
    locals.ipScan = locals.ipInformation        
	locals.ComputerInformation = {"classID": "computerInformation","name":locals.localComputer.get_name, "home":home_dir, "location":program_path, "path":current_path, "user":active_user, "has_internet":locals.localComputer.is_network_active, "active_net_card":locals.localComputer.active_net_card, "wifi_networks":locals.localComputer.wifi_networks("wlan0")}
	locals.computerInfo = locals.ComputerInformation
	locals.currentStatus = {"classID":"currentStatus", "ipInfo":locals.ipScan, "compInfo":locals.computerInfo}
	locals.currentStatus.classID = "currentStatus"
	return locals.currentStatus
end function
	// @startuml
	// title <color:purple>currentStatus Class Diagram</color>
	// 
	// class currentStatus {
	//   .. <color:blue>.compInfo</color> ..
	//   + .name : string
	//   + .home : string
	//   + .location : string
	//   + .path : string
	//   + .user : string
	//   + .has_internet : boolean
	// 
	//   .. <color:blue>.ipInfo</color> ..
	//   + local : string
	//   + public : string
	//   + gateway : string
	// }
	// 
	// note right of currentStatus
	//   * Pulls basic information
	//      on the immediate environment
	//   * Populates currentStatus Object
	// end note
	// 
	// @enduml








    load_theme = function(themefile = "default.ini")
            //Make a class file for all the local theme data so it can be properly returned as a class object
        locals.themeData = {
            "classID": "",
            "leftBorder": "",
            "rightBorder": "",
            "defaultTextColor": "",
            "alphaSetting": "",
            "borderCharacter1": "",
            "borderCharacter1Color": "",
            "borderCharacter2": "",
            "borderCharacter2Color": "",
            "borderCharacter3": "",
            "borderCharacter3Color": "",
            "noBar": "     ",
            "lowBar": "▁    ",
            "medBar": "▂▃  ",
            "highBar": "▃▄▅ ",
            "maxBar": "▄▅▇█",
            "failColor": "",
            "passColor": "",
            "poz": "",
            "poy": "",
            "pox": "",
            "pow": "",
            "pov": "",
            "iti1": "",
            "iti2": "",
            "iti3": "",
            "iti4": "",
            "iti5": "",
            "iti6": "",
            "tag1": "",
            "tag2": "",
            "tag1Color0": "",
            "tag2Color0": "",
            "tag2Color1": "",
            "tag2Color2": "",
            "signalColor0": "",
            "signalColor1": "",
            "signalColor2": "",
            "signalColor3": "",
            "signalColor4": "",
            "signalColor5": "",
            "signalColor6": "",
            "signalColor7": "",
            "signalColor8": "",
            "signalColor9": "",
            "signalColor10": "",
            "signalColor11": "",
            "ipAddressColor": "",
            "defaultTextColor": "",
            "selectionHighlightColor": "",
            "helpMenuItemColor": "",
            "helpMenuKeyColor": "",
            "loadColors":"WhiteSmoke,Red,Orange,Yellow,Green,LimeGreen",
            "loadShapes":"▖,▗,▘,▚,▝,▞"}
            airlinkThemeContent = null
            airlinkThemeList = null
            locals.airlinkThemeFile = globals.myComputer.File(home_dir + "/Airlink/Theme/" + locals.themefile)
            if typeof(locals.airlinkThemeFile) == "file" then
                locals.airlinkThemeContent = locals.airlinkThemeFile.get_content
            end if
            if typeof(locals.airlinkThemeContent) == "string" then
                locals.airlinkThemeList = locals.airlinkThemeContent.split(char(10))
            end if
            for airlinkThemeItem in locals.airlinkThemeList
                locals.airlinkThemeItemPart = locals.airlinkThemeItem.split(":")
                //playerDatabaseDir
                if locals.airlinkThemeItemPart[0] == "leftBorder" then
                    locals.themeData.leftBorder = locals.airlinkThemeItemPart[1]
                else if locals.airlinkThemeItemPart[0] == "rightBorder" then
                    locals.themeData.rightBorder = locals.airlinkThemeItemPart[1]
                else if locals.airlinkThemeItemPart[0] == "borderCharacter1" then
                    locals.themeData.borderCharacter1 = locals.airlinkThemeItemPart[1]
                else if locals.airlinkThemeItemPart[0] == "borderCharacter1Color" then
                    locals.themeData.borderCharacter1Color = locals.airlinkThemeItemPart[1]                 
                else if locals.airlinkThemeItemPart[0] == "borderCharacter2" then
                    locals.themeData.borderCharacter2 = locals.airlinkThemeItemPart[1]
                else if locals.airlinkThemeItemPart[0] == "borderCharacter2Color" then
                    locals.themeData.borderCharacter2Color = locals.airlinkThemeItemPart[1]    
                else if locals.airlinkThemeItemPart[0] == "borderCharacter3" then
                    locals.themeData.borderCharacter3 = locals.airlinkThemeItemPart[1]
                else if locals.airlinkThemeItemPart[0] == "borderCharacter3Color" then
                    locals.themeData.borderCharacter3Color = locals.airlinkThemeItemPart[1]    
                else if locals.airlinkThemeItemPart[0] == "loadShapes" then
                    locals.themeData.loadShapes = locals.airlinkThemeItemPart[1].split(",")
                else if locals.airlinkThemeItemPart[0] == "loadColors" then
                    locals.themeData.loadColors = locals.airlinkThemeItemPart[1].split(",")                    
                else if locals.airlinkThemeItemPart[0] == "noBar" then
                    locals.themeData.noBar = locals.airlinkThemeItemPart[1]
                else if locals.airlinkThemeItemPart[0] == "lowBar" then
                    locals.themeData.lowBar = locals.airlinkThemeItemPart[1]
                else if locals.airlinkThemeItemPart[0] == "medBar" then
                    locals.themeData.medBar = locals.airlinkThemeItemPart[1]
                else if locals.airlinkThemeItemPart[0] == "highBar" then
                    locals.themeData.highBar = locals.airlinkThemeItemPart[1]
                else if locals.airlinkThemeItemPart[0] == "maxBar" then
                    locals.themeData.maxBar = locals.airlinkThemeItemPart[1]
                else if locals.airlinkThemeItemPart[0] == "failColor" then
                    locals.themeData.failColor = locals.airlinkThemeItemPart[1]
